}


// scale a shape by a {double}, promoting the result to reals
template <std::size_t Rank>
constexpr auto
pyre::grid::operator*(const Shape<Rank> & shape, double scale) noexcept -> doubles_t<Rank>
{
    // make room for the result
    doubles_t<Rank> result;
    // go through the axes
    for (std::size_t axis = 0; axis < Rank; ++axis) {
        // and scale each extent
        result[axis] = scale * static_cast<double>(shape[axis]);
    }
    // all done
    return result;
}

// multiplication commutes
template <std::size_t Rank>
constexpr auto
pyre::grid::operator*(double scale, const Shape<Rank> & shape) noexcept -> doubles_t<Rank>
{
    // invoke the reference implementation
    return shape * scale;
}

// divide a shape by a {double}, promoting the result to reals
template <std::size_t Rank>
constexpr auto
pyre::grid::operator/(const Shape<Rank> & shape, double scale) noexcept -> doubles_t<Rank>
{
    // make room for the result
    doubles_t<Rank> result;
    // go through the axes
    for (std::size_t axis = 0; axis < Rank; ++axis) {
        // and scale each extent
        result[axis] = static_cast<double>(shape[axis]) / scale;
    }
    // all done
    return result;
}


