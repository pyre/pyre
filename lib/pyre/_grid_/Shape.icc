// operators

// inject a representation of the shape into a stream
template <std::size_t Rank>
auto
pyre::grid::operator<<(ostream_reference stream, const Shape<Rank> & shape) -> ostream_reference
{
    // start without a separator
    const char * sep = "";
    // go through the extents
    for (const auto & extent : shape) {
        // inject this extent
        stream << sep << extent;
        // place a separator before the next one
        sep = ", ";
    }
    // all done
    return stream;
}


// two shapes are equal when they agree at every axis
template <std::size_t Rank>
constexpr auto
pyre::grid::operator==(const Shape<Rank> & s1, const Shape<Rank> & s2) noexcept -> bool
{
    // check each axis
    for (std::size_t axis = 0; axis < Rank; ++axis) {
        // if there is a mismatch
        if (s1[axis] != s2[axis]) {
            // the shapes are not equal
            return false;
        }
    }
    // all axes matched
    return true;
}


// add two shapes component-wise
template <std::size_t Rank>
constexpr auto
pyre::grid::operator+(const Shape<Rank> & s1, const Shape<Rank> & s2) noexcept -> Shape<Rank>
{
    // make room for the result
    Shape<Rank> result;
    // go through the axes
    for (std::size_t axis = 0; axis < Rank; ++axis) {
        // and accumulate the sum
        result[axis] = s1[axis] + s2[axis];
    }
    // all done
    return result;
}


// subtract two shapes component-wise
template <std::size_t Rank>
constexpr auto
pyre::grid::operator-(const Shape<Rank> & s1, const Shape<Rank> & s2) noexcept -> Shape<Rank>
{
    // make room for the result
    Shape<Rank> result;
    // go through the axes
    for (std::size_t axis = 0; axis < Rank; ++axis) {
        // and compute the difference
        result[axis] = s1[axis] - s2[axis];
    }
    // all done
    return result;
}


// unary plus: an exact copy
template <std::size_t Rank>
constexpr auto
pyre::grid::operator+(const Shape<Rank> & shape) noexcept -> Shape<Rank>
{
    // nothing to do
    return shape;
}

// unary minus: negate every extent; note the modular arithmetic of the unsigned {value_type}
template <std::size_t Rank>
constexpr auto
pyre::grid::operator-(const Shape<Rank> & shape) noexcept -> Shape<Rank>
{
    // make room for the result
    Shape<Rank> result;
    // go through the axes
    for (std::size_t axis = 0; axis < Rank; ++axis) {
        // and negate each extent
        result[axis] = -shape[axis];
    }
    // all done
    return result;
}


// scale a shape by an {int}
template <std::size_t Rank>
constexpr auto
pyre::grid::operator*(const Shape<Rank> & shape, int scale) noexcept -> Shape<Rank>
{
    // make room for the result
    Shape<Rank> result;
    // go through the axes
    for (std::size_t axis = 0; axis < Rank; ++axis) {
        // and scale each extent
        result[axis] = static_cast<typename Shape<Rank>::value_type>(scale) * shape[axis];
    }
    // all done
    return result;
}

// multiplication commutes
template <std::size_t Rank>
constexpr auto
pyre::grid::operator*(int scale, const Shape<Rank> & shape) noexcept -> Shape<Rank>
{
    // invoke the reference implementation
    return shape * scale;
}


