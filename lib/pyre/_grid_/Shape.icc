// divide a shape by an {int}
template <std::size_t Rank>
constexpr auto
pyre::grid::operator/(const Shape<Rank> & shape, int scale) noexcept -> Shape<Rank>
{
    // make room for the result
    Shape<Rank> result;
    // go through the axes
    for (std::size_t axis = 0; axis < Rank; ++axis) {
        // and scale each extent
        result[axis] = shape[axis] / static_cast<typename Shape<Rank>::value_type>(scale);
    }
    // all done
    return result;
}

// divide a shape by a {long}
template <std::size_t Rank>
constexpr auto
pyre::grid::operator/(const Shape<Rank> & shape, long scale) noexcept -> Shape<Rank>
{
    // make room for the result
    Shape<Rank> result;
    // go through the axes
    for (std::size_t axis = 0; axis < Rank; ++axis) {
        // and scale each extent
        result[axis] = shape[axis] / static_cast<typename Shape<Rank>::value_type>(scale);
