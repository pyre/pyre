}


// cartesian product: concatenate {s1} and {s2} into a shape of rank {Rank1+Rank2}
template <std::size_t Rank1, std::size_t Rank2>
constexpr auto
pyre::grid::operator*(const Shape<Rank1> & s1, const Shape<Rank2> & s2) noexcept
    -> Shape<Rank1 + Rank2>
{
    // make room for the result
    Shape<Rank1 + Rank2> result;
    // place {s1}'s extents
    for (std::size_t axis = 0; axis < Rank1; ++axis) {
        // in the first {Rank1} slots
        result[axis] = s1[axis];
    }
    // follow with {s2}'s extents
    for (std::size_t axis = 0; axis < Rank2; ++axis) {
        // in the remaining ranks
        result[Rank1 + axis] = s2[axis];
    }
    // all done
    return result;
}


// structured binding support

// the number of components of a {Shape<Rank>} is {Rank}
template <std::size_t Rank>
struct std::tuple_size<pyre::grid::Shape<Rank>> : std::integral_constant<std::size_t, Rank> {};

// each component is a {value_type}
template <std::size_t I, std::size_t Rank>
struct std::tuple_element<I, pyre::grid::Shape<Rank>> {
    using type = typename pyre::grid::Shape<Rank>::value_type;
};

// for a const shape, each component is a {const value_type}
template <std::size_t I, std::size_t Rank>
struct std::tuple_element<I, const pyre::grid::Shape<Rank>> {
    using type = const typename pyre::grid::Shape<Rank>::value_type;
};


// get the {I}-th extent by reference
template <std::size_t I, std::size_t Rank>
constexpr auto
pyre::grid::get(Shape<Rank> & shape) noexcept -> typename Shape<Rank>::reference
{
    return shape[I];
}

// get the {I}-th extent from a temporary
template <std::size_t I, std::size_t Rank>
constexpr auto
pyre::grid::get(Shape<Rank> && shape) noexcept -> typename Shape<Rank>::rvalue_reference
{
    return std::move(shape[I]);
}

// get the {I}-th extent read-only
template <std::size_t I, std::size_t Rank>
constexpr auto
pyre::grid::get(const Shape<Rank> & shape) noexcept -> typename Shape<Rank>::const_reference
{
    return shape[I];
}

// get the {I}-th extent read-only from a const temporary
template <std::size_t I, std::size_t Rank>
constexpr auto
pyre::grid::get(const Shape<Rank> && shape) noexcept -> typename Shape<Rank>::const_rvalue_reference
{
    return std::move(shape[I]);
}


